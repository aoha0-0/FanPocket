<body class="bg-surface text-on-surface font-body min-h-screen pb-32">
  <!-- TopAppBar -->
  <header class="bg-white/80 backdrop-blur-sm sticky top-0 z-40 transition-colors border-b border-white">
  <div class="max-w-full mx-auto px-4 py-3">
    <div class="flex items-center justify-between w-full">
      <div class="flex items-center gap-3">
        <%= link_to root_path, class: "material-symbols-outlined text-on-surface-variant hover:opacity-70 transition-opacity" do %>
          arrow_back
        <% end %>
        <h1 class="font-headline font-bold text-lg text-on-surface">これからの予定</h1>
      </div>
      <div class="flex items-center gap-2 bg-white/50 px-3 py-1.5 rounded-full border border-white shadow-sm">
        <%= image_tag "logo.png", class: "w-6 h-6 object-contain", alt: "FanPocket Logo" %>
        <span class="font-headline font-bold tracking-tight text-[#2D6489]">FanPocket</span>
      </div>

    </div>
  </div>
</header>
 <main class="flex-grow px-6 max-w-3xl mx-auto w-full pt-8">
    <!-- Screen Title Section -->
    <div class="mb-10">
      <h2 class="font-headline font-extrabold text-3xl text-center tracking-tight">予定の追加</h2>
      <p class="text-center text-sm mt-2">URLを保存して新しい活動を記録しましょう</p>
    </div>

    <%= form_with model: @watchlist, class: "space-y-10" do |f| %>
      <!-- エラーメッセージ表示 -->
      <% if @watchlist.errors.any? %>
        <div class="bg-error/10 border border-error/20 text-error p-4 rounded-2xl text-sm">
          <ul class="list-disc list-inside">
            <% @watchlist.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <!-- URL Input Section -->
      <div class="space-y-3">
        <%= f.label :url, class: "font-headline font-bold text-xs uppercase tracking-widest text-primary/60 flex items-center gap-2 px-1" do %>
          <span class="material-symbols-outlined text-lg">link</span>URL
        <% end %>
        <div class="relative">
          <%= f.url_field :url, class: "w-full bg-[#f8f9fb] border-none rounded-2xl px-5 py-4 text-on-surface focus:ring-2 focus:ring-accent-soft transition-all placeholder:text-outline/40", placeholder: "https://example.com/event-page" %>
        </div>
        <%# 自動取得ボタンは将来的にJSで機能を実装する想定 %>
        <button class="text-primary font-bold text-xs flex items-center gap-1.5 hover:opacity-80 transition-opacity ml-1 bg-accent-soft/40 px-3 py-2 rounded-full active:scale-95" type="button">
          <span class="material-symbols-outlined text-sm">auto_fix</span>タイトルを自動取得する
        </button>
      </div>

      <!-- Title Input Section -->
      <div class="space-y-3">
        <%= f.label :title, class: "font-headline font-bold text-xs uppercase tracking-widest text-primary/60 flex items-center gap-2 px-1" do %>
          <span class="material-symbols-outlined text-lg">title</span>タイトル
        <% end %>
        <%= f.text_field :title, class: "w-full bg-[#f8f9fb] border-none rounded-2xl px-5 py-4 text-on-surface focus:ring-2 focus:ring-accent-soft transition-all placeholder:text-outline/40", placeholder: "グッズ予約、ライブ名など" %>
      </div>

      <!-- Date Selection Grid -->
      <div class="grid grid-cols-1 gap-8">
        <!-- Start Date -->
        <div class="space-y-3">
          <%= f.label :start_at, class: "font-headline font-bold text-xs uppercase tracking-widest text-primary/60 flex items-center gap-2 px-1" do %>
            <span class="material-symbols-outlined text-lg">calendar_today</span>開始日時
          <% end %>
          <%= f.text_field :start_at, class: "datepicker w-full bg-[#f8f9fb] border-none rounded-2xl px-5 py-4 text-on-surface focus:ring-2 focus:ring-accent-soft transition-all", placeholder: "日時を選択..." %>
        </div>

        <!-- Deadline Date -->
        <div class="space-y-3">
          <%= f.label :end_at, class: "font-headline font-bold text-xs uppercase tracking-widest text-primary/60 flex items-center gap-2 px-1" do %>
            <span class="material-symbols-outlined text-lg">timer</span>締切日時
          <% end %>
          <%= f.text_field :end_at, class: "datepicker w-full bg-[#f8f9fb] border-none rounded-2xl px-5 py-4 text-on-surface focus:ring-2 focus:ring-accent-soft transition-all", placeholder: "日時を選択..." %>
        </div>
      </div>

      <!-- Memo Section -->
      <div class="space-y-3">
        <%= f.label :memo, class: "font-headline font-bold text-xs uppercase tracking-widest text-primary/60 flex items-center gap-2 px-1" do %>
          <span class="material-symbols-outlined text-lg">description</span>メモ
        <% end %>
        <%= f.text_area :memo, class: "w-full bg-[#f8f9fb] border-none rounded-2xl px-5 py-4 text-on-surface focus:ring-2 focus:ring-accent-soft transition-all placeholder:text-outline/40 min-h-[120px]", placeholder: "持ち物、連番相手の連絡先など...", rows: 4 %>
      </div>

      <div class="pt-6 pb-20"> 
      <%= f.button class: "w-full bg-[#B6E0F3] text-[#2d6489] font-headline font-bold py-4 rounded-full puffy-shadow hover:brightness-105 transition-all active:scale-[0.97] flex items-center justify-center gap-3", type: "submit" do %>
        <span class="material-symbols-outlined font-bold">save</span>保存する
      <% end %>
    </div>
  <% end %>
  </main>

  <!-- Background Decoration -->
  <div class="fixed top-0 left-0 w-full h-full -z-10 pointer-events-none overflow-hidden">
    <div class="fixed z-0 blur-[100px] rounded-full bg-[#e0f2fe] opacity-50 w-[500px] h-[500px] -top-20 -right-20 pointer-events-none"></div>
    <div class="fixed z-0 blur-[100px] rounded-full bg-[#e0f2fe] opacity-40 w-[400px] h-[400px] -bottom-20 -left-20 pointer-events-none"></div>
  </div>
</body>